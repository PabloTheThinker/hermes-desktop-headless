[Unit]
Description=Hermes Desktop (headless via Xvfb + noVNC)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
Environment=HD_DISPLAY=99
Environment=HD_BIND=127.0.0.1
Environment=HD_VNC_PORT=5901
Environment=HD_NOVNC_PORT=6080
# Install the CLI on PATH or set absolute ExecStart
ExecStart=%h/.local/bin/hermes-desktop-headless start
ExecStop=%h/.local/bin/hermes-desktop-headless stop
TimeoutStartSec=120

[Install]
WantedBy=default.target
