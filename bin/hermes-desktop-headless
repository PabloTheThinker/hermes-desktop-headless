#!/usr/bin/env bash
# hermes-desktop-headless — Hermes Desktop on headless Linux
# Stack: Xvfb + dbus + WM + hermes desktop + x11vnc + noVNC
set -euo pipefail

_SELF="${BASH_SOURCE[0]}"
while [[ -L "$_SELF" ]]; do
  _dir="$(cd -P "$(dirname "$_SELF")" && pwd)"
  _SELF="$(readlink "$_SELF")"
  [[ "$_SELF" != /* ]] && _SELF="$_dir/$_SELF"
done
ROOT="$(cd "$(dirname "$_SELF")/.." && pwd)"
# shellcheck source=../lib/common.sh
source "$ROOT/lib/common.sh"

VERSION="$(cat "$ROOT/VERSION" 2>/dev/null || echo '0.0.0-dev')"

usage() {
  cat <<EOF
hermes-desktop-headless ${VERSION}
Run Hermes Desktop on headless Linux (Xvfb + noVNC).

Usage:
  hermes-desktop-headless <command> [options]

Commands:
  start [--foreground] [--no-vnc] [--bind ADDR] [--display N]
  stop
  restart [start-options...]
  status
  screenshot [path.png]
  url
  doctor [--install-hints]
  version
  help

Environment (optional):
  HD_DISPLAY=99                 X display number
  HD_GEOMETRY=1920x1080x24      Xvfb geometry
  HD_VNC_PORT=5901              RFB port
  HD_NOVNC_PORT=6080            Browser UI port
  HD_BIND=127.0.0.1             Listen address (localhost only by default)
  HD_STATE_DIR=\$XDG_STATE_HOME/hermes-desktop-headless
  HD_HERMES_CMD='hermes desktop --skip-build'
  HD_VNC_PASSWORD_FILE=path     Required if HD_BIND is not loopback
  HD_NOVNC_WEB=path             Override noVNC web root
  HD_WM=fluxbox|openbox|icewm   Preferred window manager
  HD_WAIT_HERMES_SEC=45         Electron ready timeout

Security: binds 127.0.0.1 by default. Reach via SSH tunnel or mesh VPN.
  ssh -N -L 6080:127.0.0.1:6080 user@host
  open http://127.0.0.1:6080/vnc.html?autoconnect=1&resize=remote
EOF
}

cmd="${1:-help}"
shift || true

case "$cmd" in
  start)      hd_start "$@" ;;
  stop)       hd_stop ;;
  restart)    hd_stop || true; hd_start "$@" ;;
  status)     hd_status ;;
  shot|screenshot) hd_screenshot "$@" ;;
  url)        hd_print_urls ;;
  doctor)     hd_doctor "$@" ;;
  version|--version|-V) echo "hermes-desktop-headless ${VERSION}" ;;
  -h|--help|help) usage ;;
  *)
    echo "unknown command: $cmd" >&2
    usage >&2
    exit 1
    ;;
esac
