#!/usr/bin/env bash
# hermes-update — run `hermes update`, then re-apply durable local Desktop patches.
# Survives git reset --hard (patches live under ~/.hermes/local-patches, not in-tree).
set -euo pipefail

export PATH="${HOME}/.local/bin:${PATH}"

HERMES_HOME="${HERMES_HOME:-$HOME/.hermes}"
PATCH_DIR="${HERMES_LOCAL_PATCHES:-$HERMES_HOME/local-patches}"
APPLY="${HERMES_APPLY_PATCHES:-}"

# Resolve apply script without machine-specific absolute paths.
_self_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [[ -z "$APPLY" ]]; then
  for c in \
    "$HOME/.local/share/hermes-desktop-headless/scripts/apply-desktop-patches.sh" \
    "$_self_dir/../scripts/apply-desktop-patches.sh" \
    "$_self_dir/../share/hermes-desktop-headless/scripts/apply-desktop-patches.sh"
  do
    if [[ -x "$c" ]]; then
      APPLY="$(cd "$(dirname "$c")" && pwd)/$(basename "$c")"
      break
    fi
  done
fi

echo "==> hermes update (preserving local Desktop patches after)"

# Don't re-apply when user only wants help/check
case "${1:-}" in
  -h|--help|help)
    hermes update --help
    exit 0
    ;;
  --check)
    exec hermes update --check
    ;;
esac

set +e
hermes update "$@"
upd=$?
set -e

if [[ $upd -ne 0 ]]; then
  echo "warning: hermes update exited $upd — still attempting patch re-apply" >&2
fi

if [[ ! -x "${APPLY:-}" ]]; then
  echo "error: apply-desktop-patches.sh not found. Install hermes-desktop-headless:" >&2
  echo "  git clone https://github.com/PabloTheThinker/hermes-desktop-headless.git" >&2
  echo "  cd hermes-desktop-headless && ./scripts/install.sh" >&2
  exit "${upd:-1}"
fi

# Sync patches from product tree into durable HERMES_HOME location if present
PRODUCT_PATCHES="$(cd "$(dirname "$APPLY")/.." && pwd)/patches"
if [[ -d "$PRODUCT_PATCHES" ]]; then
  mkdir -p "$PATCH_DIR"
  cp -f "$PRODUCT_PATCHES"/0001-*.patch \
        "$PRODUCT_PATCHES"/0002-*.patch \
        "$PRODUCT_PATCHES"/0003-*.patch \
        "$PATCH_DIR/" 2>/dev/null || true
fi

export HERMES_LOCAL_PATCHES="$PATCH_DIR"
echo "==> re-apply local patches from $PATCH_DIR"
if ! "$APPLY" --force-build; then
  echo "warning: patch re-apply had failures — see output above" >&2
  [[ $upd -ne 0 ]] && exit "$upd"
  exit 1
fi

echo "ok: update + local patches complete"
echo "  fully quit Hermes Desktop once, then reopen (or: hermes desktop --skip-build)"
exit "$upd"
